<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WMS</title>
    
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <style>
            :root {
                --primary-blue: #0091FF;
                --soft-bg: #f8f9fa;
                --text-main: #1a1a1a;
            }

            body {
                background-color: var(--soft-bg);
                font-family: 'Inter', sans-serif; 
                min-height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
                margin: 0;
                padding: 1rem;
            }

            .auth-container {
                width: 100%;  
                width: fit-content;
                min-width: 400px; 
                max-width: 1000px; 
                transition: all 0.3s ease; 
            }

            .auth-card {
                background: #ffffff;
                padding: 2.5rem;
                border-radius: 20px; 
                box-shadow: 0 10px 25px rgba(0,0,0,0.03), 0 20px 48px rgba(0,0,0,0.08);
                border: 1px solid rgba(0,0,0,0.02);
            }

            .text-muted
            {
                margin-top:8px;
            }
            .auth-header {
                text-align: center;
                margin-bottom: 2rem;
            }

                .auth-header h2 {
                    font-weight: 700;
                    letter-spacing: -0.5px;
                    color: var(--text-main);
                }

            
            .form-control {
                border-radius: 10px;
                padding: 0.75rem 1rem;
                border: 1.5px solid #eee;
                transition: all 0.2s ease;
            }

                .form-control:focus {
                    border-color: var(--primary-blue);
                    box-shadow: 0 0 0 4px rgba(0, 98, 255, 0.1);
                }

            .btn-primary {
                background-color: var(--primary-blue);
                border: none;
                border-radius: 10px;
                padding: 0.8rem;
                font-weight: 600;
                transition: transform 0.2s ease, box-shadow 0.2s ease;
            }

                .btn-primary:hover {
                    transform: translateY(-1px);
                    box-shadow: 0 5px 15px rgba(0, 98, 255, 0.2);
                    background-color: #0091FF;
                }

            .btn-outline-light-custom {
                
                border: 2px solid #0091FF !important;
                background-color: transparent !important;
                color: #0091FF !important;
                font-weight: 600;
                margin-top:12px;
                border-radius: 10px !important;
                transition: all 0.2s ease;
            }

                .btn-outline-light-custom:hover {
                    background-color: #0091FF !important;
                    border-color: #0091FF !important;
                    color: #ffffff !important;
                }

            .mt-4 {
                margin-top: 1.5rem !important;
            }

            .row {
                display: flex;
                flex-wrap: wrap;
                margin-right: -25px;
                margin-left: -25px;
            }


            .nav-pills .nav-link.active,
            .nav-pills .show  .nav-link {
                background-color: white !important; 
                color: #0091FF !important;
                align-content:center;
                border: solid 2px #0091FF;
                font-weight: 600;
            }

            .nav-pills .nav-link {
                color: #444;
                align-content: center;
                transition: 0.3s all ease;
            }

                .nav-pills .nav-link:hover:not(.active) {
                    background-color: #f8f9fa;
                    color: #000;
                    align-content: center;
                }

            @@media (max-width: 400px) {
                .auth-container {
                    min-width: 100% !important;
                }

                .auth-card {
                    padding: 2rem 1.5rem;
                }
            }
    </style>
</head>
<body>

    <div class="auth-container">
        <div class="auth-card">
            <div class="auth-header">
                <img src="~/Dashboard/logo/LoginLogo.png" alt="">
                <p class="text-muted">Admin Management Panel</p>
            </div>

            @RenderBody()
            
            @* <div class="text-center mt-4">
                <a href="/" class="text-decoration-none text-muted small">
                    <i class="bi bi-arrow-left"></i> Back 
                </a>
            </div> *@
        </div>
        
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>