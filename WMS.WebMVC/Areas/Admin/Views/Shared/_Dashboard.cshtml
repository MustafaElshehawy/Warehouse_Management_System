    <!-- jQuery UI 1.11.4 -->
    <script src="~/Dashboard/plugins/jquery-ui/jquery-ui.min.js"></script>
    <!-- Resolve conflict in jQuery UI tooltip with Bootstrap tooltip -->
        <script>
                              $(document).ready(function () {
                    // 1. تفعيل زر المنيو بشكل صريح
                    $('[data-widget="pushmenu"]').on('click', function (e) {
                        e.preventDefault();
                    });

                    // 2. وظيفة إغلاق السايد بار عند الضغط على اللينكات (للموبايل فقط)
                    function handleSidebarOnMobile() {
                        if ($(window).width() < 768) {
                            // نستخدم 'body' كمرجع لأن AdminLTE بيعتمد على الكلاسات اللي في الـ body
                            $('.nav-item > .nav-link').off('click').on('click', function () {
                                if ($('body').hasClass('sidebar-open')) {
                                    $('[data-widget="pushmenu"]').PushMenu('collapse');
                                }
                            });
                        }
                    }

                    // تشغيل الدالة عند تحميل الصفحة
                    handleSidebarOnMobile();

                    // تشغيل الدالة عند تغيير حجم الشاشة (في حالة الـ Orientation change)
                    $(window).resize(function () {
                        handleSidebarOnMobile();
                    });
                });
        </script>
