@model IEnumerable<ProductUnitCreateVM>

@{
    ViewBag.PageTitle = "إدارة الوحدات الفرعية";
    ViewBag.CardTitle = "كل الوحدات الفرعية";
}
<section class="content">
    <div class="row">
        <div class="col-12">
            <div class="card">

                <!-- /.card-header -->
                <div class="card-body">
                    <table id="example1" class="table table-bordered table-striped ">
                        <thead>
                            <tr>
                                <th>المنتج</th>
                                <th>الوحدة الكبيره</th>
                                <th>الكمية</th>
                                <th>الوحدة الصغيره</th>
                                <th>سعر</th>
                                <th>وقت الإضافة </th>
                                <th>الإضافة بواسطة </th>
                                @* <th>وقت التعديل </th>
                                <th>التعديل بواسطة </th> *@
                                @* <th>الإجراءات  </th> *@
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        @item.ProductUnit.Product.Name
                                    </td>
                                    <td>
                                        @item.ProductUnit.ParentUnit.Name
                                    </td>
                                    <td>
                                        @item.ProductUnit.UnitFactor
                                    </td>
                                    <td>
                                        @item.ProductUnit.ChildUnit.Name
                                    </td>
                                    <td>
                                        @item.ProductUnit.ParentUnitPrice
                                    </td>
                                    <td>
                                        @item.ProductUnit.CreatedAt.ToString("yyyy/MM/dd")
                                    </td>
                                    <td>
                                        @item.CreatedByName
                                    </td>
                                    @* <td>
                                        @item.ProductUnit.ModifiedAt
                                    </td>
                                    <td>
                                        @item.ModifiedByName
                                    </td> *@
                                    @* <td>

                                        <a asp-action="Update" asp-controller="ProductUnit" asp-route-id="@item.ProductUnit.Id" class="btn btn-warning"><i class="nav-icon 	fas fa-edit">تعديل</i></a>
                                    </td> *@

                                </tr>


                            }
                        </tbody>

                    </table>
                </div>
                <!-- /.card-body -->
            </div>
            <!-- /.card -->
        </div>
        <!-- /.col -->
    </div>
    <!-- /.row -->
</section>

@section Scripts {
    <script>
        $('#example1').DataTable({
            paging: true,
            lengthChange: true,
            searching: true,
            ordering: true,
            info: true,
            autoWidth: false,
            language: {
                url: "//cdn.datatables.net/plug-ins/1.13.6/i18n/ar.json"
            },
        });
    </script>
}