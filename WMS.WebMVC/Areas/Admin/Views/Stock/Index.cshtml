@model StockVM
@{
    ViewBag.PageTitle = "المخزون";
    ViewBag.CardTitle = "فلتره ";
}

<div class="container mt-3">
    <form asp-action="index" method="get">
        <div class="row">  
            <div class="col-md-9 mb-3">
                <label asp-for="@Model.WarehouseId" class="form-label fw-bold"> المخزن</label>
                <select id="@Model.WarehouseId" asp-for="@Model.WarehouseId" class="custom-select" asp-items="@Model.WarehouseList">
                    <option disabled selected>-- اختر المخزن --</option>
                </select>
                <span asp-validation-for="@Model.WarehouseId" class="text-danger"></span>
            </div>
            <div class="col-md-3 mb-3 align-content-end">
                <button type="submit" class="btn btn-custom w-100">
                    <i class="fas fa-filter"></i> تطبيق
                </button>
            </div>
        </div>
    </form>
</div>
<section class="content">
    <div class="row">
        <div class="col-12">
            <div class="card">

                <!-- /.card-header -->
                <div class="card-body">
                    <div class="table-responsive-cards">
                        <table id="example1" class="table table-bordered table-striped ">
                            <thead>
                                <tr>
                                    <th>المخزن</th>
                                    <th>المنتج</th>
                                    <th>الوحدة</th>
                                    <th>الكمية</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.StockList)
                                {
                                    <tr>
                                        <td data-label="المخزن">
                                            @item.Warehouse.Name
                                        </td>
                                        <td data-label="المنتج">
                                            @item.Product.Name
                                        </td>
                                        <td data-label="الوحدة">
                                            @item.Unit.Name
                                        </td>
                                        <td data-label="الكمية">
                                            @item.Quantity
                                        </td> 
                                    </tr>


                                }
                            </tbody>

                        </table>
                    </div>
                </div>
                <!-- /.card-body -->
            </div>
            <!-- /.card -->
        </div>
        <!-- /.col -->
    </div>
    <!-- /.row -->
</section>

@section Scripts {
    <script>
        $('#example1').DataTable({
            paging: true,
            lengthChange: true,
            searching: true,
            ordering: true,
            info: true,
            autoWidth: false,
            language: {
                url: "//cdn.datatables.net/plug-ins/1.13.6/i18n/ar.json"
            },
        });
    </script>
}



