@model ProductVM

@{
    ViewBag.PageTitle = "إدارة المنتجات";
    ViewBag.CardTitle = "إضافة منتج جديد";
}
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
                $(document).ready(function () {
            $('#galleryfiles').on('change', function (e) {
                var files = e.target.files;
                var label = $('#file-label-name');
                var display = $('#file-list-display');

                display.empty(); // مسح القائمة القديمة

                if (files.length > 0) {
                    // تحديث نص الـ Label الأساسي
                    label.text(files.length + " ملفات مختارة");

                    // إنشاء قائمة بأسماء الملفات تحت الـ Input
                    var fileNames = [];
                    for (var i = 0; i < files.length; i++) {
                        fileNames.push('<span class="badge badge-success mr-1"><i class="fas fa-image"></i> ' + files[i].name + '</span>');
                    }
                    display.html(fileNames.join(' '));
                } else {
                    label.text("اختر الصور...");
                }
            });
        });
    </script>
}
<div class="container mt-3">
    <form asp-action="Create" method="post" enctype="multipart/form-data">
        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="Product.Name" class="form-label fw-bold">اسم المنتج</label>
                <input asp-for="Product.Name" class="form-control" placeholder="أدخل اسم المنتج..." />
                <span asp-validation-for="Product.Name" class="text-danger"></span>
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="Product.CategoryId" class="form-label fw-bold">التصنيف (Category)</label>
                <select asp-for="Product.CategoryId" class="custom-select" asp-items="Model.CategoryList">
                    <option disabled selected>-- اختر التصنيف --</option>
                </select>
                <span asp-validation-for="Product.CategoryId" class="text-danger"></span>
            </div>
        </div>

        <div class="mb-3">
            <label asp-for="Product.Description" class="form-label fw-bold">الوصف</label>
            <textarea asp-for="Product.Description" class="form-control" rows="2" placeholder="أدخل وصفاً بسيطاً للمنتج..."></textarea>
            <span asp-validation-for="Product.Description" class="text-danger"></span>
        </div>

        <div class="row">
            <div class="col-md-4 mb-3">
                <label asp-for="Product.CostPrice" class="form-label fw-bold">سعر التكلفة</label>
                <input asp-for="Product.CostPrice" class="form-control" type="number" step="any" min="0" placeholder="0.00" />
                <span asp-validation-for="Product.CostPrice" class="text-danger"></span>
            </div>

            <div class="col-md-4 mb-3">
                <label asp-for="Product.SellingPrice" class="form-label fw-bold">سعر البيع</label>
                <input asp-for="Product.SellingPrice" class="form-control" type="number" step="any" min="0" placeholder="0.00" />
                <span asp-validation-for="Product.SellingPrice" class="text-danger"></span>
            </div>

            <div class="col-md-4 mb-3">
                <label asp-for="Product.SmallestUnitId" class="form-label fw-bold">أصغر وحدة قياس</label>
                <select asp-for="Product.SmallestUnitId" class="custom-select" asp-items="Model.UnitList">
                    <option disabled selected>-- اختر الوحدة الأساسية --</option>
                </select>
                <span asp-validation-for="Product.SmallestUnitId" class="text-danger"></span>
            </div>
        </div>

        <div class="mb-3">
            <label class="form-label fw-bold">صور المنتج (بحد أقصى 5 صور)</label>
            <div class="input-group">
                <div class="custom-file">
                    <input type="file" name="files" id="galleryfiles" class="custom-file-input" multiple>
                    <label class="custom-file-label" id="file-label-name" for="galleryfiles">اختر الصور...</label>
                </div>
                <div class="input-group-append">
                    <span class="input-group-text bg-black text-black-50">رفع الصور</span>
                </div>
            </div>
            <div id="file-list-display" class="mt-2 text-muted small"></div>
        </div>

        <div class="mt-4 mb-5">
            <button type="submit" class="btn btn-custom px-5">إضافة المنتج</button>
            <a asp-action="Index" asp-controller="Product" class="btn btn-warning">رجوع للقائمة</a>
        </div>
    </form>
</div>

