@model Unit
@{
    ViewBag.PageTitle = "إدارة الوحدات الرئسية";
    ViewBag.CardTitle = "تعديل وحدة رئيسية";
}
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
<div class="container mt-3">
    <form asp-action="Update" method="post">
        <div class="mb-3">
            <input hidden asp-for="Id" />
            <label asp-for="Name" class="form-label"><i class="nav-icon fas fa-solid fa-ruler ml-2"></i>إسم الوحدة</label>
            <input asp-for="Name" class="form-control" placeholder="إكتب إسم الوحدة" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <button type="submit" class="btn btn-custom">حفظ التعديل</button>
            <a asp-action="Index" asp-controller="Category" class="btn btn-warning">الرجوع</a>
        </div>
    </form>
</div>