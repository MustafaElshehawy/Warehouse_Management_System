@page
@model LoginModel

@{
    ViewData["Title"] = "تسجيل الدخول";
}

<div class="row">

    <section>
        <form id="account" method="post">

              
            <div asp-validation-summary="All" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="Input.Email"><i class="nav-icon fa fa-envelope" style="color: #042C63 !important; margin-left: 8px;"></i>البريد الإلكتروني </label>
                <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Input.Password"><i class="nav-icon fas fa-key" style="color: #042C63 !important; margin-left: 8px;"></i>كلمة المرور </label>
                <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" />
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>
            <div class="form-group">
                <div class="checkbox">
                    <label asp-for="Input.RememberMe">
                        <input asp-for="Input.RememberMe" />
                        تذكرني؟
                    </label>
                </div>
            </div>
            <p>
                <a id="forgot-password" asp-page="./ForgotPassword" style="color: #042C63 !important">نسيت كلمة المرور؟</a>
            </p>
            <div class="form-group">
                <button type="submit" class="btn btn-primary w-100 py-2 shadow-sm">
                    تسجيل الدخول
                </button>
            </div>
        </form>
    </section>

